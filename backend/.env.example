# Copy this file to backend/.env for local development. Never commit real secrets.
APP_ENVIRONMENT=development
APP_SERVICE_NAME=pharmacycrm
APP_VERSION=dev
APP_COMMIT_SHA=unknown
APP_DEBUG=false
APP_MIN_SCHEMA_VERSION=18
APP_MAX_SCHEMA_VERSION=18
APP_WORKER_PROTOCOL=1

HTTP_ADDRESS=:8080
HTTP_TLS_MODE=disabled

POSTGRES_RUNTIME_DSN=postgres://pharmacycrm:local-dev-password@localhost:5432/pharmacycrm?sslmode=disable
POSTGRES_MIGRATION_DSN=postgres://pharmacycrm_migrator:local-dev-password@localhost:5432/pharmacycrm?sslmode=disable
POSTGRES_MIN_CONNECTIONS=1
POSTGRES_MAX_CONNECTIONS=10
POSTGRES_CONNECTION_CAPACITY=20

AUTH_JWT_ISSUER=pharmacycrm-local
AUTH_JWT_AUDIENCE=pharmacycrm-api
AUTH_JWT_ALGORITHM=EdDSA
AUTH_JWT_PRIVATE_KEY=replace-with-local-ed25519-private-key
AUTH_REFRESH_TOKEN_PEPPER=replace-with-a-random-local-secret
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=strict

PROXY_CORS_ALLOWED_ORIGINS=http://localhost:5173
PROXY_CORS_ALLOW_CREDENTIALS=true
PROXY_CORS_TRUST_FORWARDED_HEADERS=false

LOGGING_LEVEL=info
LOGGING_FORMAT=console
LOGGING_FILE_PATH=var/log/pharmacycrm/app.log
LOGGING_MAX_SIZE_MB=100
LOGGING_MAX_BACKUPS=10
LOGGING_MAX_AGE_DAYS=30
LOGGING_COMPRESS=true

TELEMETRY_METRICS_ADDRESS=:9090
TELEMETRY_EXPORT_TIMEOUT=5s

WORKER_PROTOCOL_VERSION=1
WORKER_OWNER=pharmacycrm-worker-local-1
WORKER_CONCURRENCY=1
WORKER_POLL_INTERVAL=1s
WORKER_LEASE_DURATION=30s
WORKER_MAX_CLAIM=100
WORKER_DRAIN_TIMEOUT=20s

STORAGE_IMPORT_ROOT=var/imports
STORAGE_MAX_UPLOAD_BYTES=10485760
STORAGE_RETENTION=720h
